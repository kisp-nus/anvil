// Sender: dynamic, Receiver: static → Valid signal required from the sender

chan ch {
    left res : (logic[8]@#3) @#1 - @dyn
}

proc syn1_example_receiver (endp : left ch) {
    reg data : logic[8];
    loop {
        let data = recv endp.res >>
        dprint "Data Receive: %d" (data) >>
        cycle 1 
    }
}

